APP_NAME=AgriVerse
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- DATABASE ---
# Opsi 1 (paling simpel & gratis, disarankan untuk mulai): SQLite
DB_CONNECTION=sqlite
# Setelah composer create-project, jalankan:
#   touch database/database.sqlite   (Windows: buat file kosong lewat File Explorer)
# lalu hapus 4 baris DB_* di bawah ini (tidak dibutuhkan untuk SQLite).

# Opsi 2: MySQL (misal pakai Laragon/XAMPP di lokal, atau MySQL dari hosting)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=agriverse
# DB_USERNAME=root
# DB_PASSWORD=
# DB_FOREIGN_KEYS=true

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync
